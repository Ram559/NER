NODE_ENV=development
PRETTY_LOGS=false

POSTGRES_USER=ner
POSTGRES_PASSWORD=ner_password
POSTGRES_DB=ner_news
DATABASE_URL=postgresql://ner:ner_password@postgres:5432/ner_news?schema=public

API_PORT=4000
API_PUBLIC_URL=http://localhost:8080/api
WEB_PUBLIC_URL=http://localhost:8080
ADMIN_TOKEN=change-me-long-random-token
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CRON_ENABLED=true
INITIAL_INGESTION_ENABLED=true
INGESTION_CRON=*/10 * * * *
INGESTION_CONCURRENCY=6
AUTO_APPROVE_ARTICLES=true
PUBLIC_REFRESH_ENABLED=false
POLITICAL_FILTER_ENABLED=true

# Optional. If unset, the backend uses deterministic local summaries/tags.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

NUXT_PUBLIC_API_BASE=/api
NUXT_API_INTERNAL_BASE=http://api:4000/api
