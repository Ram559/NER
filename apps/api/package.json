    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "fastest-levenshtein": "^1.0.16",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.72.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "robots-parser": "^3.0.1",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.11.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
